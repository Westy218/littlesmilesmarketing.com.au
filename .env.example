# ═══════════════════════════════════════════════
# Little Smiles Marketing — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════

# Form submission endpoint (server-side handler)
# This is the URL your contact form posts to
FORM_ENDPOINT=https://your-backend.com/api/submit-form

# Email service (e.g., SendGrid, Mailgun, Resend)
EMAIL_API_KEY=your_email_api_key_here
EMAIL_FROM=hello@repositioned.business
EMAIL_TO=hello@repositioned.business

# CRM integration (optional)
CRM_API_KEY=your_crm_api_key_here
CRM_WEBHOOK_URL=https://your-crm.com/webhook

# Google Analytics (optional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# reCAPTCHA (recommended for forms)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Deployment
NODE_ENV=production
PORT=3000
